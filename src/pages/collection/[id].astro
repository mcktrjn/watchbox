---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import { Watch } from "lucide-react";
import { createClient } from "@/lib/supabase";
import { getWatchById } from "@/lib/watches";

const { user } = Astro.locals;
const { id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);
const watchItem = supabase && user && id ? await getWatchById(supabase, user.id, id) : null;

if (!watchItem) {
  Astro.response.status = 404;
}

const formattedDate = watchItem
  ? new Date(watchItem.created_at).toLocaleDateString(undefined, { year: "numeric", month: "long", day: "numeric" })
  : null;
---

<Layout title={watchItem ? watchItem.name : "Watch not found"}>
  <div class="bg-cosmic min-h-screen p-4 sm:p-8">
    <Topbar />
    <div class="mx-auto max-w-2xl">
      <a href="/collection" class="mb-6 inline-block text-sm text-blue-100/60 hover:text-blue-100">
        &larr; Back to collection
      </a>
      {
        watchItem ? (
          <div class="overflow-hidden rounded-2xl border border-white/10 bg-white/5">
            <div class="flex aspect-square items-center justify-center bg-white/5">
              {watchItem.photo_url ? (
                <img src={watchItem.photo_url} alt={watchItem.name} class="h-full w-full object-cover" />
              ) : (
                <Watch className="size-16 text-blue-100/40" />
              )}
            </div>
            <div class="p-6">
              <h1 class="text-2xl font-bold text-white">{watchItem.name}</h1>
              <p class="mt-1 text-sm text-blue-100/60">Added on {formattedDate}</p>
            </div>
          </div>
        ) : (
          <div class="rounded-2xl border border-white/10 bg-white/5 px-6 py-16 text-center">
            <h1 class="text-lg font-semibold text-white">Watch not found</h1>
            <p class="mt-1 text-sm text-blue-100/60">This watch doesn't exist or you don't have access to it.</p>
          </div>
        )
      }
    </div>
  </div>
</Layout>
